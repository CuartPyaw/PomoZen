{
  "manifest_version": 3,
  "name": "PomoZen - 竹林番茄钟",
  "version": "1.0.0",
  "description": "融合中国传统美学与现代技术的番茄工作法计时器",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "action": {
    "default_popup": "popup/index.html"
  },
  "options_page": "settings/index.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}